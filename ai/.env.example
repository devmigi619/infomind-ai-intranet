# AI (FastAPI) 로컬 환경변수 예시 — 이 파일을 ai/.env.local로 복사 후 사용
# .env.local은 .gitignore되어 있어 커밋되지 않음

# JWT 서명 키 — Spring Boot(backend/.env.local)와 동일한 값이어야 함
JWT_SECRET=local-dev-secret-key-must-be-at-least-32-characters

# Ollama (로컬 직접 설치 시)
OLLAMA_URL=http://localhost:11434

# Qdrant (Phase 3 RAG 작업 시 필요. 로컬은 보류)
QDRANT_URL=http://localhost:6333

# 모델
LLM_MODEL=qwen2.5:8b
EMBEDDING_MODEL=bona/bge-m3
EMBEDDING_DIMENSIONS=1024

# CORS — 프론트엔드 주소
ALLOWED_ORIGINS=["http://localhost:8081"]
